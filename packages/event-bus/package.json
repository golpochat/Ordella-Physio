  },
  "devDependencies": {
    "@nestjs/common": "^10.4.15",
    "@ordella/config-typescript": "workspace:*",
    "@types/node": "^22.10.2",
    "nats": "^2.28.3",
    "reflect-metadata": "^0.2.2",
    "picocolors": "^1.1.1",
    
    "rxjs": "^7.8.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
