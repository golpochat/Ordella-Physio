{
  "name": "@ordella/database",
  "version": "0.0.0",
  "private": true,
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "dotenv": "^16.4.7"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@prisma/client": "^6.0.0",
    "prisma": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "prisma": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^10.4.15",
    "@ordella/config-typescript": "workspace:*",
    "@prisma/client": "^6.19.3",
    "@types/node": "^22.10.2",
    "prisma": "^6.19.3",
    "reflect-metadata": "^0.2.2",
    "picocolors": "^1.1.1",
    
    "rxjs": "^7.8.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
