{
  "name": "@ordella/observability",
  "version": "0.0.0",
  "private": true,
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@opentelemetry/api": "^1.9.0",
    "express": "^4.18.0",
    "prom-client": "^15.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/sdk-node": {
      "optional": true
    },
    "@opentelemetry/instrumentation-http": {
      "optional": true
    },
    "@opentelemetry/instrumentation-nestjs-core": {
      "optional": true
    },
    "@opentelemetry/instrumentation-prisma": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^10.4.15",
    "@opentelemetry/api": "^1.9.0",
    "@ordella/config-typescript": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "express": "^4.21.2",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "picocolors": "^1.1.1",
    
    "rxjs": "^7.8.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
