# Traefik dashboard basic auth (generate: htpasswd -nb admin your-password)
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD=changeme

# ACME / Let's Encrypt
ACME_EMAIL=admin@ordella.local
ACME_DOMAIN=ordella.local

# OpenTelemetry tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# Docker network shared with ordella-physio services (infrastructure/deployment-layer uses ordella-network)
ORDELLA_NETWORK=ordella_physio_backend
