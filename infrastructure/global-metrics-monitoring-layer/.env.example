# Grafana (metrics stack — separate from logging Grafana on 3030)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme-metrics-grafana
GRAFANA_PORT=3031

# Prometheus / Alertmanager
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093

# Tempo
TEMPO_PORT=3200
TEMPO_OTLP_HTTP_PORT=4318
TEMPO_OTLP_GRPC_PORT=4317

# Alerting (placeholder)
ALERT_EMAIL_TO=alerts@example.com
ALERT_EMAIL_FROM=monitoring@ordella.local

# Environment label applied to all metrics
ORDELLA_ENVIRONMENT=development

# Docker network (matches infrastructure/deployment-layer: ordella-network)
ORDELLA_NETWORK=ordella_physio_backend
