# Redis authentication
REDIS_PASSWORD=changeme-redis-password

# Connection (for microservices and scripts)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://:changeme-redis-password@localhost:6379

# Redis Insight UI
REDIS_INSIGHT_PORT=8002
REDIS_STACK_INSIGHT_PORT=8001

# Docker network (matches infrastructure/deployment-layer: ordella-network)
ORDELLA_NETWORK=ordella_physio_backend

# Backup directory (host path, relative to this folder)
REDIS_BACKUP_DIR=./backups
