# Repository root (auto-detected by scripts if empty)
REPO_ROOT=

# Node / package manager
NODE_VERSION=20
PNPM_VERSION=9.15.4

# Playwright E2E
PLAYWRIGHT_BASE_URL=http://localhost:3010
PLAYWRIGHT_HEADLESS=true

# CI placeholders
CI_DOCKER_REGISTRY=ghcr.io/ordella
CI_DOCKER_IMAGE_PREFIX=ordella-physio
CI_TURBO_TOKEN=
CI_TURBO_TEAM=

# Tooling paths (relative to repo root)
TOOLING_LAYER_PATH=infrastructure/developer-tooling-layer
