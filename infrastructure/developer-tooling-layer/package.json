{
  "name": "@ordella/developer-tooling-layer",
  "version": "0.0.0",
  "private": true,
  "description": "Unified development standards, linting, formatting, testing, and CI/CD templates for ordella-physio",
  "scripts": {
    "bootstrap": "bash scripts/bootstrap.sh",
    "verify": "bash scripts/verify.sh",
    "format:all": "bash scripts/format-all.sh",
    "lint:all": "bash scripts/lint-all.sh",
    "test:all": "bash scripts/test-all.sh",
    "generate:env": "bash scripts/generate-env.sh",
    "test:e2e": "playwright test --config playwright/playwright.config.ts",
    "test:e2e:ui": "playwright test --config playwright/playwright.config.ts --ui"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@nestjs/testing": "^10.4.15",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-nestjs": "^1.2.3",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "eslint-import-resolver-typescript": "^3.7.0",
    "identity-obj-proxy": "^3.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
