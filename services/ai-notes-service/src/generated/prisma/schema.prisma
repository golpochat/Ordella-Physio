generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AiUsageLog {
  id               String   @id @default(cuid())
  tenantId         String
  userId           String
  operation        String
  modelName        String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  metadata         Json?
  createdAt        DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, userId])
  @@map("ai_usage_logs")
}

model AiOutputRecord {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String
  operation     String
  patientId     String?
  appointmentId String?
  therapistId   String?
  inputSummary  String?
  output        Json
  accepted      Boolean?
  createdAt     DateTime @default(now())

  @@index([tenantId, userId])
  @@index([tenantId, operation])
  @@map("ai_output_records")
}
