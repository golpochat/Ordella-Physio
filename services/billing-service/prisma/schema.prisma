generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOIDED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model Invoice {
  id            String        @id @default(cuid())
  tenantId      String
  patientId     String
  appointmentId String?
  invoiceNumber String        @unique
  status        InvoiceStatus @default(DRAFT)
  subtotal      Decimal       @default(0) @db.Decimal(12, 2)
  tax           Decimal       @default(0) @db.Decimal(12, 2)
  discount      Decimal       @default(0) @db.Decimal(12, 2)
  total         Decimal       @default(0) @db.Decimal(12, 2)
  currency      String        @default("USD")
  dueDate       DateTime?
  notes         String?
  taxRateId     String?
  discountId    String?
  taxRate       TaxRate?      @relation(fields: [taxRateId], references: [id])
  discountRef   Discount?     @relation(fields: [discountId], references: [id])
  items         InvoiceItem[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([tenantId])
  @@index([tenantId, patientId])
  @@index([tenantId, status])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([invoiceId])
  @@map("invoice_items")
}

model TaxRate {
  id         String    @id @default(cuid())
  tenantId   String
  name       String
  percentage Decimal   @db.Decimal(5, 2)
  taxType    String?
  invoices   Invoice[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([tenantId])
  @@map("tax_rates")
}

model Discount {
  id        String       @id @default(cuid())
  tenantId  String
  name      String
  type      DiscountType
  value     Decimal      @db.Decimal(12, 2)
  isActive  Boolean      @default(true)
  invoices  Invoice[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([tenantId])
  @@map("discounts")
}

enum StripeSubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAUSED
}

model TenantBillingAccount {
  id                     String                    @id @default(cuid())
  tenantId               String                    @unique
  stripeCustomerId       String                    @unique
  defaultPaymentMethodId String?
  email                  String?
  subscription           TenantStripeSubscription?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  @@map("tenant_billing_accounts")
}

model TenantStripeSubscription {
  id                   String                   @id @default(cuid())
  tenantBillingId      String                   @unique
  billingAccount       TenantBillingAccount     @relation(fields: [tenantBillingId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String                   @unique
  stripePriceId        String
  plan                 String
  status               StripeSubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean                  @default(false)
  canceledAt           DateTime?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  @@map("tenant_stripe_subscriptions")
}

model StripeWebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  eventType     String
  processedAt   DateTime @default(now())

  @@map("stripe_webhook_events")
}
