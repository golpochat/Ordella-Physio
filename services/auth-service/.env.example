# Server
PORT=3051
NODE_ENV=development

# Database
DATABASE_URL=postgresql://ordella:ordella@localhost:5432/ordella_auth?schema=public

# JWT
JWT_SECRET=change-me-jwt-secret-min-32-characters-long
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Messaging
NATS_URL=nats://localhost:4222
REDIS_URL=redis://localhost:6379

# Email (communication service integration)
EMAIL_FROM=noreply@ordella.com
COMMUNICATION_SERVICE_URL=http://localhost:3058

# Password reset / verification
PASSWORD_RESET_EXPIRES_IN=1h
EMAIL_VERIFICATION_EXPIRES_IN=24h

# Observability
LOG_LEVEL=info
METRICS_ENABLED=true
