NODE_ENV=development
PORT=3071
DATABASE_URL=postgresql://physio:physio@localhost:5433/ordella_file_storage?schema=public
JWT_ACCESS_SECRET=change-me-to-a-secure-secret-at-least-32-chars

STORAGE_DEFAULT_PROVIDER=LOCAL
STORAGE_FAILOVER_PROVIDERS=S3,GCS,LOCAL
STORAGE_LOCAL_BASE_PATH=./uploads/files
CDN_ENABLED=false
CDN_BASE_URL=https://cdn.sheba360.com
CDN_SIGN_URLS=false
FILE_STORAGE_PUBLIC_BASE_URL=http://localhost:3049/files
FILE_STORAGE_SIGNED_URL_TTL_SECONDS=300
FILE_STORAGE_MAX_BYTES=20971520
AUDIT_SERVICE_URL=http://localhost:3070

# Optional ClamAV daemon (omit to use clean stub)
# CLAMAV_HOST=localhost
# CLAMAV_PORT=3310

STORAGE_S3_BUCKET=
STORAGE_S3_REGION=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=

STORAGE_GCS_BUCKET=
STORAGE_GCS_PROJECT_ID=

LOG_LEVEL=info
CORS_ORIGIN=*
