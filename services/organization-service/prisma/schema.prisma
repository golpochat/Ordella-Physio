generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
}

model Organization {
  id                  String               @id @default(cuid())
  name                String
  code                String               @unique
  description         String?
  primaryContactName  String
  primaryContactEmail String
  primaryContactPhone String?
  status              OrganizationStatus   @default(ACTIVE)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  tenantLinks         OrganizationTenant[]
  configs             OrganizationConfig[]

  @@map("organizations")
}

model OrganizationConfig {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  namespace       String
  data            Json
  updatedByUserId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([organizationId, namespace])
  @@index([organizationId])
  @@map("organization_configs")
}

model OrganizationTenant {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenantId       String
  createdAt      DateTime     @default(now())

  @@unique([organizationId, tenantId])
  @@unique([tenantId])
  @@map("organization_tenants")
}
